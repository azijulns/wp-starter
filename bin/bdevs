#!/usr/bin/env php
<?php

/**
 * bdevs — WP Starter CLI
 *
 * Usage:
 *   bdevs <command> [arguments]
 *
 * Commands:
 *   class <ClassName> [folder]   Create a class, auto-wire includes() & init_plugin()
 *   help                         Show this help message
 *
 * Examples:
 *   bdevs class MyFeature
 *   bdevs class PostTypes   includes
 *   bdevs class Menu_Widget widgets
 */

$rootDir = getcwd();
$command = $argv[1] ?? 'help';

switch ($command) {
    case 'class':
        cmd_make_class($argv, $rootDir);
        break;

    case 'css':
        cmd_make_asset($argv, $rootDir, 'css');
        break;

    case 'js':
        cmd_make_asset($argv, $rootDir, 'js');
        break;

    case 'help':
    case '--help':
    case '-h':
    default:
        show_help();
        break;
}

// ─── Commands ─────────────────────────────────────────────────────────────────

function cmd_make_class(array $argv, string $rootDir): void
{
    $className = $argv[2] ?? null;
    $folder    = isset($argv[3]) ? rtrim($argv[3], '/\\') : 'classes';

    if (!$className) {
        echo <<<HELP

  Usage:  bdevs class <ClassName> [folder]

  ClassName   PascalCase or Snake_Case class name (e.g. MyFeature, Post_Types)
  folder      Sub-directory for the file           (default: classes)

  Examples:
    bdevs class MyFeature
    bdevs class PostTypes    includes
    bdevs class Menu_Widget  widgets

HELP;
        exit(1);
    }

    if (!preg_match('/^[A-Za-z_][A-Za-z0-9_]*$/', $className)) {
        echo "Error: '$className' is not a valid PHP class name.\n";
        exit(1);
    }

    $fileName = class_to_filename($className);
    $filePath = $rootDir . DIRECTORY_SEPARATOR . $folder . DIRECTORY_SEPARATOR . $fileName;

    $mainPluginFile = find_main_plugin_file($rootDir);
    if (!$mainPluginFile) {
        echo "Error: Could not find the main plugin file (no 'Plugin Name:' header in root).\n";
        exit(1);
    }

    if (file_exists($filePath)) {
        echo "Error: File already exists: {$folder}/{$fileName}\n";
        exit(1);
    }

    if (!is_dir(dirname($filePath))) {
        mkdir(dirname($filePath), 0755, true);
    }

    // ── Widget folder: Elementor widget stub ──────────────────────────────────
    if ($folder === 'widgets') {
        $prefix      = detect_plugin_prefix($rootDir);          // e.g. WPPS
        $prefixLower = strtolower($prefix);                     // e.g. wpps
        $widgetClass = $prefix . '_' . $className;              // e.g. WPPS_My_Slider
        $widgetName  = $prefixLower . '_' . strtolower($className); // e.g. wpps_my_slider
        $widgetTitle = ucwords(str_replace('_', ' ', $className));  // e.g. My Slider
        $textDomain  = detect_text_domain($rootDir);            // e.g. my-plugin
        $widgetSlug  = $prefixLower . '-' . str_replace('_', '-', strtolower($className)); // e.g. wpps-my-slider

        $classContent = <<<PHP
<?php

if (!defined('ABSPATH')) {
\texit;
}

use Elementor\Widget_Base;
use Elementor\Controls_Manager;

class {$widgetClass} extends Widget_Base {

\tpublic function get_name() {
\t\treturn '{$widgetName}';
\t}

\tpublic function get_title() {
\t\treturn esc_html__('{$widgetTitle}', '{$textDomain}');
\t}

\tpublic function get_icon() {
\t\treturn 'eicon-code';
\t}

\tpublic function get_categories() {
\t\treturn ['basic'];
\t}

\tprotected function register_controls() {
\t\t\$this->start_controls_section(
\t\t\t'content_section',
\t\t\t[
\t\t\t\t'label' => esc_html__('Content', '{$textDomain}'),
\t\t\t\t'tab'   => Controls_Manager::TAB_CONTENT,
\t\t\t]
\t\t);

\t\t\$this->end_controls_section();
\t}

\tprotected function render() {
\t\t\$settings = \$this->get_settings_for_display();
\t\t?>
\t\t<div class="{$widgetSlug}">
\t\t\t<!-- TODO: render widget output -->
\t\t</div>
\t\t<?php
\t}
}
PHP;
        file_put_contents($filePath, $classContent);
        echo "Created:  {$folder}/{$fileName}\n";

        $widgetInitFile = $rootDir . '/widgets/init.php';
        if (!file_exists($widgetInitFile)) {
            echo "Warning:  widgets/init.php not found. Wire the class manually.\n";
        } else {
            $initContent = file_get_contents($widgetInitFile);
            $initChanged = false;

            $requireStatement  = "require_once {$prefix}_PLUGIN_DIR . '/widgets/{$fileName}';";
            $registerStatement = "\$widgets_manager->register(new \\{$widgetClass}());";

            if (strpos($initContent, $requireStatement) !== false) {
                echo "Notice:   Include already present in init_widgets().\n";
            } else {
                [$patched, $ok] = insert_into_method(
                    $initContent,
                    '/\bfunction\s+init_widgets\s*\(/',
                    $requireStatement
                );
                if ($ok) {
                    $initContent = $patched;
                    $initChanged = true;
                    echo "Updated:  widgets/init.php → init_widgets() ← {$requireStatement}\n";
                } else {
                    echo "Warning:  Could not patch init_widgets(). Add manually:\n";
                    echo "          {$requireStatement}\n";
                }
            }

            if (strpos($initContent, $registerStatement) !== false) {
                echo "Notice:   Register already present in init_widgets().\n";
            } else {
                [$patched, $ok] = insert_into_method(
                    $initContent,
                    '/\bfunction\s+init_widgets\s*\(/',
                    $registerStatement
                );
                if ($ok) {
                    $initContent = $patched;
                    $initChanged = true;
                    echo "Updated:  widgets/init.php → init_widgets() ← {$registerStatement}\n";
                } else {
                    echo "Warning:  Could not patch init_widgets(). Add manually:\n";
                    echo "          {$registerStatement}\n";
                }
            }

            if ($initChanged) {
                file_put_contents($widgetInitFile, $initContent);
            }
        }
    } else {
        // ── Non-widget: plain class stub ──────────────────────────────────────
        $baseNamespace = detect_base_namespace($rootDir);
        $namespace     = $baseNamespace . '\\' . folder_to_ns_segment($folder);

        $classContent = <<<PHP
<?php

namespace {$namespace};

defined('ABSPATH') || die();

class {$className} {
    public function __construct() {
        // TODO: register your WordPress hooks here
    }
}
PHP;
        file_put_contents($filePath, $classContent);
        echo "Created:  {$folder}/{$fileName}\n";
        // ── Other folders: patch main plugin file ─────────────────────────────
        $pluginContent = file_get_contents($mainPluginFile);
        $pluginName    = basename($mainPluginFile);
        $changed       = false;

        $prefix           = detect_plugin_prefix($rootDir);
        $includeStatement = "require_once {$prefix}_PLUGIN_DIR . '{$folder}/{$fileName}';";
        if (strpos($pluginContent, $includeStatement) !== false) {
            echo "Notice:   Include already present in includes().\n";
        } else {
            [$patched, $ok] = insert_into_method(
                $pluginContent,
                '/\bfunction\s+includes\s*\(/',
                $includeStatement
            );
            if ($ok) {
                $pluginContent = $patched;
                $changed       = true;
                echo "Updated:  {$pluginName} → includes() ← {$includeStatement}\n";
            } else {
                echo "Warning:  Could not patch includes(). Add manually:\n";
                echo "          {$includeStatement}\n";
            }
        }

        $baseNs        = detect_base_namespace($rootDir);
        $fqcn          = $baseNs . '\\' . folder_to_ns_segment($folder) . '\\' . $className;
        $initStatement = "new {$fqcn}();";
        if (strpos($pluginContent, $initStatement) !== false) {
            echo "Notice:   Instantiation already present in init_plugin().\n";
        } else {
            [$patched, $ok] = insert_into_method(
                $pluginContent,
                '/\bfunction\s+init_plugin\s*\(/',
                $initStatement
            );
            if ($ok) {
                $pluginContent = $patched;
                $changed       = true;
                echo "Updated:  {$pluginName} → init_plugin() ← new {$fqcn}()\n";
            } else {
                echo "Warning:  Could not patch init_plugin(). Add manually:\n";
                echo "          {$initStatement}\n";
            }
        }

        if ($changed) {
            file_put_contents($mainPluginFile, $pluginContent);
        }
    }

    echo "\nDone! Class '{$className}' is ready in {$folder}/{$fileName}\n";
}

function cmd_make_asset(array $argv, string $rootDir, string $type): void
{
    $name    = $argv[2] ?? null;
    $isAdmin = isset($argv[3]) && strtolower($argv[3]) === 'admin';

    if (!$name) {
        echo "\n  Usage:  bdevs {$type} <filename> [admin]\n\n";
        echo "  admin   Optional. Enqueues in admin_enqueue_scripts instead.\n\n";
        echo "  Examples:\n";
        echo "    bdevs {$type} my-feature\n";
        echo "    bdevs {$type} admin-panel admin\n\n";
        exit(1);
    }

    // Normalise: strip extension if provided, force kebab-case
    $name     = preg_replace('/\.' . $type . '$/', '', strtolower($name));
    $name     = preg_replace('/[^a-z0-9-]/', '-', $name);
    $fileName = $name . '.' . $type;
    $subDir   = 'assets/' . $type;
    $filePath = $rootDir . '/' . $subDir . '/' . $fileName;

    if (file_exists($filePath)) {
        echo "Error: File already exists: {$subDir}/{$fileName}\n";
        exit(1);
    }

    if (!is_dir(dirname($filePath))) {
        mkdir(dirname($filePath), 0755, true);
    }

    // Write blank asset file with a starter comment
    $stub = $type === 'css'
        ? "/* {$name} */\n"
        : "/* global jQuery */\n(function ($) {\n    'use strict';\n\n    // TODO: {$name}\n\n})(jQuery);\n";

    file_put_contents($filePath, $stub);
    echo "Created:  {$subDir}/{$fileName}\n";

    // ── Patch AssetsManager ───────────────────────────────────────────────────
    $assetsFile = find_assets_manager($rootDir);
    if (!$assetsFile) {
        echo "Warning:  AssetsManager not found. Enqueue manually.\n";
        echo "\nDone! {$type} file '{$fileName}' is ready in {$subDir}/\n";
        return;
    }

    $prefix      = detect_plugin_prefix($rootDir);
    $prefixLower = strtolower($prefix);                 // e.g. wpps
    $handle      = $prefixLower . '-' . $name;          // e.g. wpps-my-feature
    $constantDir = $prefix . '_PLUGIN_ASSETS';          // e.g. WPPS_PLUGIN_ASSETS
    $constantVer = $prefix . '_PLUGIN_VERSION';         // e.g. WPPS_PLUGIN_VERSION

    $content = file_get_contents($assetsFile);

    if ($type === 'css') {
        $statement = "wp_enqueue_style( '{$handle}', {$constantDir} . '{$type}/{$fileName}', [], {$constantVer}, 'all' );";
    } else {
        $statement = "wp_enqueue_script( '{$handle}', {$constantDir} . '{$type}/{$fileName}', ['jquery'], {$constantVer}, true );";
    }

    $methodRegex  = $isAdmin
        ? '/\bfunction\s+enqueue_admin_scripts\s*\(/'
        : '/\bfunction\s+enqueue_scripts\s*\(/';
    $methodLabel  = $isAdmin ? 'enqueue_admin_scripts()' : 'enqueue_scripts()';

    if (strpos($content, $statement) !== false) {
        echo "Notice:   Already enqueued in AssetsManager.\n";
    } else {
        [$patched, $ok] = insert_into_method($content, $methodRegex, $statement);
        if ($ok) {
            file_put_contents($assetsFile, $patched);
            echo "Updated:  " . basename($assetsFile) . " → {$methodLabel} ← {$statement}\n";
        } else {
            echo "Warning:  Could not patch {$methodLabel}. Add manually:\n";
            echo "          {$statement}\n";
        }
    }

    echo "\nDone! {$type} file '{$fileName}' is ready in {$subDir}/\n";
}

function show_help(): void
{
    echo <<<HELP

  bdevs — WP Starter CLI

  Usage:
    bdevs <command> [arguments]

  Commands:
    class <ClassName> [folder]   Create a class file and auto-wire it
    css   <filename> [admin]     Create a CSS file and enqueue it in AssetsManager
    js    <filename> [admin]     Create a JS file and enqueue it in AssetsManager
    help                         Show this help

  Examples:
    bdevs class MyFeature
    bdevs class PostTypes   includes
    bdevs class Menu_Widget widgets
    bdevs css my-feature
    bdevs css admin-styles admin
    bdevs js  my-feature
    bdevs js  admin-panel  admin

HELP;
}

// ─── Helpers ──────────────────────────────────────────────────────────────────

function class_to_filename(string $name): string
{
    $name = str_replace('_', '-', $name);
    $name = preg_replace('/([a-z\d])([A-Z])/', '$1-$2', $name);
    return strtolower($name) . '.php';
}

function folder_to_ns_segment(string $folder): string
{
    return implode(
        '\\',
        array_map('ucfirst', explode('/', str_replace('\\', '/', $folder)))
    );
}

function detect_base_namespace(string $rootDir): string
{
    foreach (['includes', 'widgets', 'classes'] as $sub) {
        foreach (glob($rootDir . '/' . $sub . '/*.php') ?: [] as $file) {
            if (preg_match('/^namespace\s+([A-Za-z\\\\]+)\\\\/m', file_get_contents($file), $m)) {
                return $m[1];
            }
        }
    }
    return 'WPPluginStarter';
}

function detect_plugin_prefix(string $rootDir): string
{
    $mainFile = find_main_plugin_file($rootDir);
    if ($mainFile) {
        // e.g. define('WPPS_PLUGIN_DIR', ...) → WPPS
        if (preg_match("/define\('([A-Z0-9]+)_PLUGIN_DIR'/", file_get_contents($mainFile), $m)) {
            return $m[1];
        }
    }
    return 'WPPS';
}

function detect_text_domain(string $rootDir): string
{
    $mainFile = find_main_plugin_file($rootDir);
    if ($mainFile) {
        if (preg_match('/Text Domain:\s*(.+)/i', file_get_contents($mainFile), $m)) {
            return trim($m[1]);
        }
    }
    return '{{PLUGIN_TEXT_DOMAIN}}';
}

function find_assets_manager(string $rootDir): ?string
{
    foreach (glob($rootDir . '/includes/*.php') ?: [] as $file) {
        if (stripos(basename($file), 'assets') !== false) {
            return $file;
        }
    }
    return null;
}

function find_main_plugin_file(string $rootDir): ?string
{
    foreach (glob($rootDir . '/*.php') ?: [] as $file) {
        if (strpos(file_get_contents($file), 'Plugin Name:') !== false) {
            return $file;
        }
    }
    return null;
}

function insert_into_method(string $content, string $methodRegex, string $newStatement): array
{
    $crlf  = strpos($content, "\r\n") !== false;
    $lines = explode("\n", str_replace("\r\n", "\n", $content));
    $total = count($lines);

    $inMethod        = false;
    $methodIndent    = -1;
    $lastBodyLineIdx = -1;
    $lastBodyIndent  = '';

    for ($i = 0; $i < $total; $i++) {
        $line    = $lines[$i];
        $trimmed = rtrim(ltrim($line), "\r");
        $indent  = strlen($line) - strlen($trimmed);

        if (!$inMethod) {
            if (preg_match($methodRegex, $line)) {
                $inMethod     = true;
                $methodIndent = $indent;
            }
            continue;
        }

        if ($trimmed === '}' && $indent <= $methodIndent) {
            break;
        }

        if ($trimmed !== '') {
            $lastBodyLineIdx = $i;
            $lastBodyIndent  = str_repeat($line[0] === "\t" ? "\t" : ' ', $indent);
        }
    }

    if ($lastBodyLineIdx === -1) {
        return [$content, false];
    }

    array_splice($lines, $lastBodyLineIdx + 1, 0, [$lastBodyIndent . $newStatement]);
    $result = implode("\n", $lines);
    return [$crlf ? str_replace("\n", "\r\n", $result) : $result, true];
}
